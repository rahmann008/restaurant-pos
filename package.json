{
  "name": "restaurant-pos",
  "private": true,
  "version": "1.0.0",
  "description": "SaaS Restaurant POS System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run start:dev --workspace=api",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.4",
    "@nestjs/typeorm": "^11.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.21.0",
    "typeorm": "^1.0.0"
  }
}
