# =====================================
# APP CONFIG
# =====================================
APP_NAME=restaurant-pos
APP_ENV=development
APP_PORT=3001

# =====================================
# DATABASE (SUPABASE / POSTGRES)
# =====================================
DATABASE_URL=postgresql://username:password@localhost:5432/restaurant_pos

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =====================================
# AUTH (JWT)
# =====================================
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=1d

# =====================================
# MULTI-TENANT CONFIG
# =====================================
DEFAULT_TENANT_ID=demo-restaurant

# =====================================
# PRINTER CONFIG (FOR FUTURE MODULE)
# =====================================
PRINTER_PROTOCOL=TCP
PRINTER_DEFAULT_PORT=9100

# =====================================
# LOGGING
# =====================================
LOG_LEVEL=debug
